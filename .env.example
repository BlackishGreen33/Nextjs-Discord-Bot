NEXT_PUBLIC_APPLICATION_ID=
PUBLIC_KEY=
BOT_TOKEN=
REGISTER_COMMANDS_KEY=
DISCORD_GATEWAY_TOKEN=

# Storage driver: prisma (default) or redis
STORAGE_DRIVER=prisma

# Prisma / Postgres
DATABASE_URL=

# Optional: Redis storage adapter
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_NAMESPACE=

# Media mode: embedded (default), remote, or disabled
MEDIA_MODE=embedded
MEDIA_SERVICE_BASE_URL=
MEDIA_SERVICE_TOKEN=
MEDIA_TIMEOUT_MS=

# Optional: comma-separated allowed domains for media links
MEDIA_ALLOWED_DOMAINS=

# Embedded translate provider: disabled (default) or libretranslate
TRANSLATE_PROVIDER=disabled
TRANSLATE_API_BASE_URL=
TRANSLATE_API_KEY=

# GIF mode: disabled (default) or remote
GIF_MODE=disabled
GIF_SERVICE_BASE_URL=
GIF_SERVICE_TOKEN=

# gif-worker only
FFMPEG_TIMEOUT_SEC=
MAX_GIF_DURATION_SEC=
GIF_SCALE_WIDTH=
GIF_FPS=

# Listener-only
GATEWAY_ATTACHMENT_MAX_BYTES=
GATEWAY_ATTACHMENT_MAX_ITEMS=
GATEWAY_ATTACHMENT_TIMEOUT_MS=

# Legacy compatibility aliases
# MEDIA_WORKER_BASE_URL=
# MEDIA_WORKER_TOKEN=
# MEDIA_WORKER_TIMEOUT_MS=
