NEXT_PUBLIC_APPLICATION_ID=
PUBLIC_KEY=
BOT_TOKEN=

# Custom secret key to register your commands
REGISTER_COMMANDS_KEY=

# Optional: Upstash Redis for shared rate limit, FAQ storage, and guild settings
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: namespace prefix for Redis keys (default: discord-bot)
REDIS_NAMESPACE=

# Optional: external media worker for preview, translate, and GIF actions
MEDIA_WORKER_BASE_URL=
MEDIA_WORKER_TOKEN=
MEDIA_WORKER_TIMEOUT_MS=

# Optional: comma-separated allowed domains for media links
# Example: x.com,twitter.com,pixiv.net,www.pixiv.net,bsky.app
MEDIA_ALLOWED_DOMAINS=

# Optional: dedicated token for gateway listener process
DISCORD_GATEWAY_TOKEN=

# Optional: gateway listener attachment relay settings for playable image/video previews
GATEWAY_ATTACHMENT_MAX_BYTES=
GATEWAY_ATTACHMENT_MAX_ITEMS=
GATEWAY_ATTACHMENT_TIMEOUT_MS=
